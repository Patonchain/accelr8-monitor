# Provided to playwright + report script at run time.
# Local dev: copy to .env.local and fill in.
# CI: set as GitHub Actions secrets (same names).

# Stripe TEST mode (NOT live)
STRIPE_TEST_SECRET_KEY=sk_test_...
STRIPE_TEST_PUBLISHABLE_KEY=pk_test_...

# Claude vision API for screenshot inspection
ANTHROPIC_API_KEY=sk-ant-...

# Resend for the daily email alert
RESEND_API_KEY=re_...
ALERT_TO_EMAIL=pat@joinaccelr8.com
ALERT_FROM_EMAIL=monitor@joinaccelr8.com

# CRM monitor user (added to allowlist, password set via accelr8-crm seed script)
CRM_MONITOR_EMAIL=monitor@joinaccelr8.com
CRM_MONITOR_PASSWORD=
